{
  "name": "claude-code",
  "display_name": "Claude Code",
  "type": "chat-tui",
  "input_mode": "natural_language",
  "launch": {
    "command": "claude",
    "flags": [],
    "env": {}
  },
  "patterns": {
    "prompt": "❯\\s|^\\$\\s",
    "thinking": "⠋|⠙|⠹|⠸|⠼|⠴|⠦|⠧|⠇|⠏",
    "complete": "✓|✔|Done|Complete",
    "error": "Error:|error:|ERR!|FAIL|Failed",
    "question": "\\(y\\/n\\)|\\(Y\\/n\\)|Yes\\/No|Continue\\?"
  },
  "states": {
    "thinking": {
      "indicator": "spinner",
      "report": false
    },
    "complete": {
      "indicator": "checkmark",
      "report": true,
      "priority": "normal"
    },
    "error": {
      "indicator": "error_text",
      "report": true,
      "priority": "high"
    },
    "question": {
      "indicator": "prompt_text",
      "report": true,
      "priority": "high"
    }
  },
  "report_templates": {
    "complete": "Task completed successfully",
    "error": "Error encountered: {summary}",
    "question": "Waiting for input: {summary}",
    "thinking": "Working on task..."
  }
}
